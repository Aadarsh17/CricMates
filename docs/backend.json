
{
  "entities": {
    "Team": {
      "title": "Team",
      "type": "object",
      "description": "Represents a cricket team participating in matches and leagues.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "ownerId": { "type": "string" },
        "matchesWon": { "type": "number" },
        "matchesLost": { "type": "number" },
        "matchesDrawn": { "type": "number" },
        "totalRunsScored": { "type": "number" },
        "totalRunsConceded": { "type": "number" },
        "totalBallsFaced": { "type": "number" },
        "totalBallsBowled": { "type": "number" },
        "totalWicketsTaken": { "type": "number" },
        "netRunRate": { "type": "number" }
      },
      "required": ["id", "name", "ownerId", "matchesWon", "matchesLost", "matchesDrawn", "totalRunsScored", "totalWicketsTaken", "netRunRate", "totalBallsFaced", "totalBallsBowled"]
    },
    "Player": {
      "title": "Player",
      "type": "object",
      "description": "Details about an individual cricket player.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "teamId": { "type": "string" },
        "role": { "type": "string" },
        "battingStyle": { "type": "string" },
        "isWicketKeeper": { "type": "boolean" },
        "isRetired": { "type": "boolean" },
        "matchesPlayed": { "type": "number" },
        "runsScored": { "type": "number" },
        "ballsFaced": { "type": "number" },
        "wicketsTaken": { "type": "number" },
        "ballsBowled": { "type": "number" },
        "runsConceded": { "type": "number" },
        "highestScore": { "type": "number" },
        "bestBowlingFigures": { "type": "string" },
        "careerCVP": { "type": "number" }
      },
      "required": ["id", "name", "role", "battingStyle", "matchesPlayed", "runsScored", "wicketsTaken", "careerCVP"]
    },
    "Match": {
      "title": "Match",
      "type": "object",
      "description": "Details about a specific match.",
      "properties": {
        "id": { "type": "string" },
        "team1Id": { "type": "string" },
        "team2Id": { "type": "string" },
        "team1SquadPlayerIds": { "type": "array", "items": { "type": "string" } },
        "team2SquadPlayerIds": { "type": "array", "items": { "type": "string" } },
        "totalOvers": { "type": "number" },
        "status": { "type": "string" },
        "tossWinnerTeamId": { "type": "string" },
        "tossDecision": { "type": "string" },
        "currentInningNumber": { "type": "number" },
        "resultDescription": { "type": "string" },
        "matchDate": { "type": "string", "format": "date-time" },
        "umpireId": { "type": "string" },
        "potmPlayerId": { "type": "string" },
        "potmCvpScore": { "type": "number" }
      },
      "required": ["id", "team1Id", "team2Id", "status", "totalOvers", "matchDate"]
    },
    "Umpire": {
      "title": "Umpire",
      "type": "object",
      "description": "Details about a match official (Umpire).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "style": { "type": "string", "description": "Umpire's officiating style or experience level." },
        "matchesOfficiated": { "type": "number" }
      },
      "required": ["id", "name"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/umpires/{umpireId}": {
      "schema": { "$ref": "#/entities/Umpire" },
      "description": "Umpire profile information."
    },
    "/teams/{teamId}": {
      "schema": { "$ref": "#/entities/Team" },
      "description": "Team definitions and seasonal totals."
    },
    "/players/{playerId}": {
      "schema": { "$ref": "#/entities/Player" },
      "description": "Player career profiles and statistics."
    },
    "/matches/{matchId}": {
      "schema": { "$ref": "#/entities/Match" },
      "description": "Match metadata and configuration."
    },
    "/matches/{matchId}/innings/{inningId}": {
      "schema": { "type": "object" },
      "description": "Specific inning details and live scores."
    },
    "/matches/{matchId}/innings/{inningId}/deliveryRecords/{deliveryRecordId}": {
      "schema": { "type": "object" },
      "description": "Ball-by-ball delivery records."
    }
  }
}
