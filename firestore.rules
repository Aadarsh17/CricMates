
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL READ ACCESS
     * Critical for transparency in scoring and public leaderboards.
     */
    match /{document=**} {
      allow read: if true;
    }

    /**
     * COLLECTION GROUP: deliveryRecords
     * Specifically authorizes aggregation of ball-by-ball data for career analytics.
     */
    match /{path=**}/deliveryRecords/{document} {
      allow read: if true;
    }

    /**
     * AUTHENTICATED WRITES
     * Ensure only authenticated users can modify data.
     */
    match /{document=**} {
      allow write: if request.auth != null;
    }

    /**
     * UMPIRE PROFILES
     * Allow umpires to update their own profiles.
     */
    match /umpires/{umpireId} {
      allow get: if true;
      allow write: if request.auth != null && request.auth.uid == umpireId;
    }
  }
}
