/**
 * CricMates - ScoresTracker Firestore Security Rules
 *
 * Updated for prototype efficiency:
 * - Allows any authenticated user to perform CRUD on core entities.
 * - This ensures Umpires can manage records without complex ownership checks.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    match /umpires/{umpireId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /teams/{teamId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /players/{playerId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /matches/{matchId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();

      match /innings/{inningId} {
        allow get, list: if true;
        allow create, update, delete: if isSignedIn();

        match /deliveryRecords/{deliveryRecordId} {
          allow get, list: if true;
          allow create, update, delete: if isSignedIn();
        }
      }
    }
  }
}