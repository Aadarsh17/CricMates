/**
 * CricMates - Professional Cricket Scoring Security Rules
 * 
 * Simplified rules to ensure broad read access for scoreboard, 
 * player statistics, and collection group queries.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- COLLECTION GROUP READ ACCESS ---
    // This is the CRITICAL rule for the stats engine to work.
    // It allows reading 'deliveryRecords' from any depth in the database.
    match /{path=**}/deliveryRecords/{document} {
      allow read: if true;
    }

    // --- GLOBAL READ ACCESS ---
    // Allow reading any document in the database to support public scoreboard and profiles.
    match /{document=**} {
      allow read: if true;
      // Writing requires authentication (Umpire role)
      allow write: if request.auth != null;
    }

    // --- PROTECTED ROLES ---
    match /umpires/{umpireId} {
      allow get: if request.auth != null;
      allow list, create, update, delete: if false;
    }
  }
}