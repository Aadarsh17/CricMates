/**
 * CricMates - ScoresTracker Firestore Security Rules
 *
 * This configuration allows broad read access for all match data to support
 * real-time scoring and comprehensive player career statistics via collection group queries.
 * Write access is restricted to authenticated users (Umpires).
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- COLLECTION GROUP RULES ---
    // Specifically allow reading delivery records across all matches for statistics.
    match /{path=**}/deliveryRecords/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{path=**}/innings/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- GENERAL ACCESS ---
    // Allow broad read access to support the public scoreboard and player profiles.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- PROTECTED ROLES ---
    match /umpires/{umpireId} {
      allow get: if request.auth != null;
      allow list, create, update, delete: if false;
    }
  }
}