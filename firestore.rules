/**
 * CricMates - Professional Cricket Scoring Security Rules
 * 
 * Rules optimized for public read access to scoreboard and statistics,
 * with write access restricted to verified Umpires.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- COLLECTION GROUP RULES ---
    // Specifically allow reading delivery records across all matches for statistics.
    // This match pattern is required for collectionGroup('deliveryRecords') queries.
    match /{path=**}/deliveryRecords/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- GENERAL ACCESS ---
    // Allow broad read access to support the public scoreboard, team profiles, and player rankings.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- PROTECTED ROLES ---
    match /umpires/{umpireId} {
      allow get: if request.auth != null;
      allow list, create, update, delete: if false;
    }
  }
}