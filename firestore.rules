rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AUTHENTICATION HELPER
     * Checks if the user is a verified league official.
     */
    function isVerifiedOfficial() {
      return request.auth != null && 
             get(/databases/$(database)/documents/umpires/$(request.auth.uid)).data.isVerified == true;
    }

    /**
     * PUBLIC DATA
     * Allow everyone to read match stats, teams, and players.
     */
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isVerifiedOfficial();
      
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isVerifiedOfficial();
      }
    }

    match /teams/{teamId} {
      allow read: if true;
      allow write: if isVerifiedOfficial();
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if isVerifiedOfficial();
    }

    /**
     * UMPIRE PROFILES
     * An umpire can only edit their own profile.
     * New umpires can create their initial profile.
     */
    match /umpires/{umpireId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == umpireId;
    }

    /**
     * SETTINGS & BRANDING
     * Global league settings can only be managed by verified officials.
     */
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isVerifiedOfficial();
    }

    /**
     * COLLECTION GROUP READS
     * Allow historical analytics to be read by everyone.
     */
    match /{path=**}/deliveryRecords/{deliveryId} {
      allow read: if true;
      allow write: if isVerifiedOfficial();
    }

    /**
     * GLOBAL FALLBACK
     * Deny everything else by default.
     */
    match /{document=**} {
      allow read: if true;
      allow write: if isVerifiedOfficial();
    }
  }
}