
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL COLLECTION GROUP AUTHORIZATION
     * Explicitly allow collection group queries for historical analytics.
     */
    match /{path=**}/deliveryRecords/{deliveryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * MATCHES & HIERARCHY
     * Allow authenticated users (Umpires) full control over match data.
     */
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      // Recursive wildcard ensures all subcollections (innings, deliveries) are covered
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    /**
     * TEAMS & PLAYERS
     */
    match /teams/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * UMPIRE PROFILES
     */
    match /umpires/{umpireId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == umpireId;
    }

    /**
     * GLOBAL FALLBACK
     */
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
