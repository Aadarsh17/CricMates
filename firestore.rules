
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL COLLECTION GROUP AUTHORIZATION
     * Explicitly allow collection group queries for historical analytics.
     * This must be at the top level to resolve permission issues across the app.
     */
    match /{path=**}/deliveryRecords/{deliveryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * MATCHES & INNINGS
     */
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      match /innings/{inningId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    /**
     * TEAMS & PLAYERS
     */
    match /teams/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * UMPIRE PROFILES
     */
    match /umpires/{umpireId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == umpireId;
    }

    /**
     * GLOBAL FALLBACK
     */
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
