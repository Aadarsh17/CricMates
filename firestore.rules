rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL READ ACCESS
     * Allows all users to see scores, rankings, and stats.
     * This is critical for collectionGroup queries to work across the database.
     */
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * EXPLICIT COLLECTION GROUP: deliveryRecords
     * Specifically authorizes aggregation of ball-by-ball data for player stats.
     */
    match /{path=**}/deliveryRecords/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * SYSTEM PATHS
     * Restricted write access to maintain league integrity.
     */
    match /umpires/{umpireId} {
      allow get: if request.auth != null;
      allow list, create, update, delete: if false;
    }
  }
}