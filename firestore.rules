/**
 * CricMates - ScoresTracker Firestore Security Rules
 *
 * This configuration allows broad read access for all match data to support
 * real-time scoring and comprehensive player career statistics via collection group queries.
 * Write access is restricted to authenticated users (Umpires).
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- COLLECTION GROUP RULES (CRITICAL) ---
    // These rules must be explicitly defined to allow collectionGroup() queries.
    // They match any collection with the specified ID anywhere in the hierarchy.
    
    match /{path=**}/deliveryRecords/{deliveryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{path=**}/innings/{inningId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- BROAD ACCESS RULES ---
    // Provides fallback read access for top-level collections like /teams, /players, etc.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- SPECIFIC PROTECTED PATHS ---
    match /umpires/{umpireId} {
      allow get: if request.auth != null;
      allow list, create, update, delete: if false;
    }
  }
}