/**
 * CricMates - Professional Cricket Scoring Security Rules
 * 
 * Optimized for broad read access to support collection group queries 
 * and real-time statistics aggregation across all match formats.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL READ ACCESS ---
    // This recursive wildcard is the most robust way to allow both 
    // standard collection reads and deep Collection Group queries.
    match /{document=**} {
      allow read: if true;
      // Writing requires authentication (Umpire role)
      allow write: if request.auth != null;
    }

    // --- PROTECTED ROLES ---
    // Specific paths can still have targeted logic if needed, 
    // but the global read above covers the stats engine needs.
    match /umpires/{umpireId} {
      allow get: if request.auth != null;
      allow list, create, update, delete: if false;
    }
  }
}