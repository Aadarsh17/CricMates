
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * COLLECTION GROUP: deliveryRecords
     * Authorized for all users to enable historical analytics and rankings.
     * This rule must explicitly match the collection group.
     */
    match /{path=**}/deliveryRecords/{deliveryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * INNINGS SUB-COLLECTIONS
     * Explicit rules for sub-collections to avoid ambiguities.
     */
    match /matches/{matchId}/innings/{inningId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * GLOBAL ACCESS
     * Allow read access to all documents. Write access requires authentication.
     */
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * UMPIRE PROFILES
     * Specific rule for umpire-only management.
     */
    match /umpires/{umpireId} {
      allow write: if request.auth != null && request.auth.uid == umpireId;
    }
  }
}
