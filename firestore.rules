/**
 * CricMates - ScoresTracker Firestore Security Rules
 *
 * Optimized for robust Collection Group support:
 * - Top-level recursive wildcard allows collectionGroup queries for 'deliveryRecords'.
 * - Explicit read/write rules for all collections.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Collection Group Rule ---
    // This allows real-time statistics calculation across all match innings.
    match /{allPaths=**}/deliveryRecords/{deliveryRecordId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- Standard Collection Rules ---

    match /umpires/{umpireId} {
      allow get: if request.auth != null;
      allow list, create, update, delete: if false;
    }

    match /teams/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /innings/{inningId} {
        allow read: if true;
        allow write: if request.auth != null;

        // Individual ball records are already covered by the collection group rule above,
        // but this provides additional clarity for direct sub-collection access.
        match /deliveryRecords/{deliveryRecordId} {
          allow read: if true;
          allow write: if request.auth != null;
        }
      }
    }
  }
}