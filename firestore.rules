
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * COLLECTION GROUP: deliveryRecords
     * Explicitly authorize group queries for ball-by-ball data at any depth.
     * This MUST be defined with the {path=**} recursive wildcard for collection group queries to work.
     */
    match /{path=**}/deliveryRecords/{deliveryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * GLOBAL READ ACCESS
     * Allow anyone to read any document. This is critical for public leaderboards and scorecards.
     */
    match /{document=**} {
      allow read: if true;
    }

    /**
     * AUTHENTICATED WRITES
     * Ensure only authenticated users (Umpires) can modify data.
     */
    match /{document=**} {
      allow write: if request.auth != null;
    }

    /**
     * UMPIRE PROFILES
     * Specific rule for umpire-only self-management.
     */
    match /umpires/{umpireId} {
      allow write: if request.auth != null && request.auth.uid == umpireId;
    }
  }
}
