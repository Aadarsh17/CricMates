/**
 * CricMates - ScoresTracker Firestore Security Rules
 *
 * Updated for robust Collection Group support:
 * - Top-level recursive wildcard allows collectionGroup queries for 'deliveryRecords'.
 * - Simplified auth checks using standard request.auth patterns.
 * - Allows any user to read match and player data.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Collection Group Rules (Must be top-level for broad support) ---
    match /{path=**}/deliveryRecords/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- Standard Collection Rules ---

    match /umpires/{umpireId} {
      allow get: if request.auth != null;
      allow list, create, update, delete: if false;
    }

    match /teams/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /innings/{inningId} {
        allow read: if true;
        allow write: if request.auth != null;

        // Note: individual deliveryRecords are already covered by the group rule above.
        match /deliveryRecords/{deliveryRecordId} {
          allow read: if true;
          allow write: if request.auth != null;
        }
      }
    }
  }
}
