/**
 * CricMates - ScoresTracker Firestore Security Rules
 *
 * Updated for prototype efficiency and Collection Group support:
 * - Explicitly allows collectionGroup queries for 'deliveryRecords' at the top level.
 * - Allows any authenticated user to perform CRUD on core entities.
 * - This ensures Umpires can manage records without complex ownership checks.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Group Rules ---
    // These MUST be defined with a recursive wildcard {path=**} to support collectionGroup() queries.
    // This allows the player profile statistics engine to scan all match deliveries.
    match /{path=**}/deliveryRecords/{deliveryRecordId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Standard Collection Rules ---

    match /umpires/{umpireId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /teams/{teamId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isSignedIn();

      match /innings/{inningId} {
        allow read: if true;
        allow write: if isSignedIn();

        match /deliveryRecords/{deliveryRecordId} {
          allow read: if true;
          allow write: if isSignedIn();
        }
      }
    }
  }
}
