rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * COLLECTION GROUP RULES
     * These must be defined to allow queries across different match/inning subcollections.
     */
    match /{path=**}/deliveryRecords/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * GLOBAL RULES
     * Allows broad read access for scoreboard transparency and specific write access for Umpires.
     */
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * PROTECTED SYSTEM PATHS
     */
    match /umpires/{umpireId} {
      allow get: if request.auth != null;
      allow list, create, update, delete: if false;
    }
  }
}