
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL READ ACCESS
     * Critical for transparency in scoring and public leaderboards.
     */
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * COLLECTION GROUP: deliveryRecords
     * Specifically authorizes aggregation of ball-by-ball data for historical analysis.
     */
    match /{path=**}/deliveryRecords/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * SYSTEM PATHS
     * Restricted write access to maintain league integrity.
     */
    match /umpires/{umpireId} {
      allow get: if true;
      allow list, create, update, delete: if false;
    }
  }
}
