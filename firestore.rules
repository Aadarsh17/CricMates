/**
 * CricMates - ScoresTracker Firestore Security Rules
 *
 * Updated for rapid prototyping:
 * - Simplified Umpire check: Any signed-in user can act as an umpire for matches they create.
 * - Public Read, Owner/Role-Based Write remains the core pattern.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    function isMatchLive(status) {
      return status == 'live';
    }

    // --- Collection Rules ---

    match /umpires/{umpireId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /teams/{teamId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.ownerId) && (request.resource.data.ownerId == resource.data.ownerId);
      allow delete: if isExistingOwner(resource.data.ownerId);
    }

    match /players/{playerId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.ownerId) && (request.resource.data.ownerId == resource.data.ownerId);
      allow delete: if isExistingOwner(resource.data.ownerId);
    }

    match /matches/{matchId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.umpireId == request.auth.uid;
      allow update: if resource != null && isOwner(resource.data.umpireId) && isMatchLive(resource.data.status) && (request.resource.data.umpireId == resource.data.umpireId);
      allow delete: if isExistingOwner(resource.data.umpireId);

      match /innings/{inningId} {
        allow get, list: if true;
        allow create: if isSignedIn() && request.resource.data.umpireId == request.auth.uid;
        allow update: if resource != null && isOwner(resource.data.umpireId) && isMatchLive(resource.data.matchStatus) && (request.resource.data.umpireId == resource.data.umpireId);
        allow delete: if isExistingOwner(resource.data.umpireId);

        match /deliveryRecords/{deliveryRecordId} {
          allow get, list: if true;
          allow create: if isSignedIn() && request.resource.data.umpireId == request.auth.uid;
          allow update: if resource != null && isOwner(resource.data.umpireId) && isMatchLive(resource.data.matchStatus);
          allow delete: if isExistingOwner(resource.data.umpireId);
        }
      }
    }
  }
}