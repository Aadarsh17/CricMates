
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * COLLECTION GROUP: deliveryRecords
     * Explicitly allowed for all users to enable historical analytics.
     * This MUST be defined to support group queries across all matches.
     */
    match /{path=**}/deliveryRecords/{deliveryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * MATCHES & INNINGS
     */
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      match /innings/{inningId} {
        allow read: if true;
        allow write: if request.auth != null;
        
        match /deliveryRecords/{deliveryId} {
          allow read: if true;
          allow write: if request.auth != null;
        }
      }
    }

    /**
     * TEAMS & PLAYERS
     */
    match /teams/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * UMPIRE PROFILES
     */
    match /umpires/{umpireId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == umpireId;
    }

    /**
     * GLOBAL FALLBACK
     */
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
