
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL COLLECTION GROUP AUTHORIZATION
     * Allow historical analytics to be read by everyone.
     * Write access is strictly restricted to authenticated Umpires.
     */
    match /{path=**}/deliveryRecords/{deliveryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * MATCHES & INNINGS
     * Public can view scores in real-time.
     * Only authenticated Umpires (request.auth != null) can record balls or update status.
     */
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    /**
     * TEAMS & PLAYERS
     * Public can view profiles and standings.
     * Only Umpires can register new players or teams.
     */
    match /teams/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * UMPIRE PROFILES
     * An umpire can only edit their own profile.
     */
    match /umpires/{umpireId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == umpireId;
    }

    /**
     * SETTINGS & BRANDING
     * Global league settings can only be managed by authenticated officials.
     */
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * GLOBAL FALLBACK
     * Deny everything else by default.
     */
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
