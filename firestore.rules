
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * COLLECTION GROUP: deliveryRecords
     * Explicitly authorize group queries for ball-by-ball data at any depth.
     * This is critical for history-based player analytics and head-to-head comparisons.
     * Placement at the top ensures these take priority for collectionGroup() calls.
     */
    match /{path=**}/deliveryRecords/{deliveryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * GLOBAL ACCESS
     * Allow anyone to read any document. Critical for public leaderboards and scorecards.
     * Ensure only authenticated users (Umpires) can modify data.
     */
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * UMPIRE PROFILES
     * Specific rule for umpire-only self-management.
     */
    match /umpires/{umpireId} {
      allow write: if request.auth != null && request.auth.uid == umpireId;
    }
  }
}
