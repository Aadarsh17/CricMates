/**
 * CricMates - ScoresTracker Firestore Security Rules
 *
 * This configuration allows broad read access for all match data to support
 * real-time scoring and comprehensive player career statistics via collection group queries.
 * Write access is restricted to authenticated users (Umpires).
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- BROAD READ ACCESS ---
    // This allows reading ANY document in the database, including subcollections.
    // This is necessary for collectionGroup queries to work without path-specific denials.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- SPECIFIC COLLECTION GROUP RULES ---
    // Even with the broad rule above, explicit collectionGroup rules are best practice
    // for complex queries across subcollections.
    match /{path=**}/deliveryRecords/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- PROTECTED COLLECTIONS ---
    // Specifically protect sensitive paths if any (none currently identified as sensitive)
    match /umpires/{umpireId} {
      allow get: if request.auth != null;
      allow list, create, update, delete: if false;
    }
  }
}