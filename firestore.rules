/**
 * CricMates - Professional Cricket Scoring Security Rules
 * 
 * Optimized for broad read access to support collection group queries 
 * and real-time statistics aggregation.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL READ ACCESS ---
    // Essential for public scoreboards, leaderboards, and collection group queries.
    // match /{document=**} covers both direct and collection group reads in Rules v2.
    match /{document=**} {
      allow read: if true;
      // Writing requires authentication (Umpire role)
      allow write: if request.auth != null;
    }

    // --- PROTECTED ROLES ---
    match /umpires/{umpireId} {
      allow get: if request.auth != null;
      allow list, create, update, delete: if false;
    }
  }
}